{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "go",
      "runtimeArgs": ["run", "."],
      "port": 8080,
      "cwd": "backend",
      "env": { "GOROOT": "C:/Program Files/Go" }
    }
  ]
}
